{
  "name": "lit-ssr-css-modules",
  "version": "1.0.0",
  "description": "A demonstration repo of Lit+SSR with CSS Module scripts and Constructable Stylesheets",
  "type": "module",
  "main": "index.js",
  "keywords": [
    "Lit",
    "SSR",
    "Web Components",
    "Constructable Stylesheets"
  ],
  "author": "Owen Buckley <owen@thegreenhouse.io>",
  "scripts": {
    "build:register": "node register-hook.js",
    "build:import": "node --import @lit-labs/ssr-dom-shim/register-css-hook.js node-loader.js"
  },
  "dependencies": {
    "@lit-labs/ssr": "^4.1.0",
    "@lit-labs/ssr-dom-shim": "^1.6.0",
    "lit": "^3.3.2"
  }
}
